# === Producción (Neon / cualquier PostgreSQL serverless) ===
# Si se define DATABASE_URL, los campos individuales de abajo son ignorados para el defaultPool
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# === Desarrollo local (PostgreSQL local) ===
# Comentar DATABASE_URL y usar estas variables para entorno local
DB_DEFAULT_USER=postgres
DB_HOST=localhost
DB_NAME=apple_hub
DB_PASSWORD_DEFAULT=your_postgres_password
DB_PORT=5432

# Roles de base de datos (definidos en el SQL pero no usados aún en los API routes)
DB_ADMIN_USER=admin_user
DB_PASSWORD_ADMIN=admin2025
DB_EMPLOYEE_USER=employee_user
DB_PASSWORD_EMPLOYEE=employee2025

# JWT
JWT_SECRET=your_super_secret_key_here_min_32_chars
